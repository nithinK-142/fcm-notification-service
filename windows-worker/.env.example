# FCM Sync Worker — configuration
# Place this file next to fcm-sync.exe on the Windows server.
# Lines starting with # are ignored.

# MongoDB URIs
LOCAL_MONGO_URI=mongodb://username:password@localhost:27017/?authSource=admin
LOCAL_DATABASE=your_local_db
LOCAL_COLLECTION=users

ATLAS_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
ATLAS_DATABASE=your_atlas_db
ATLAS_COLLECTION=recipients

# Environment: "prod" redirects logs to LOG_FILE_PATH, "dev" logs to stdout
APP_ENV=dev

# How often to sync (in minutes). Default: 30
SYNC_INTERVAL_MINUTES=30

# Ops per BulkWrite batch. Default: 500
BATCH_SIZE=500

# Concurrent goroutines writing to Atlas. Default: 4
# Lower if Atlas throws rate limit errors, raise if syncs are too slow.
WORKER_COUNT=4

# Where to write logs when running as a Windows service
LOG_FILE_PATH=C:\fcm-sync\fcm-sync.log